# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Brand name placeholder - set your real store name here.
NEXT_PUBLIC_STORE_NAME=Ethnica
# Comma-separated emails auto-granted admin on profile upsert.
ADMIN_EMAILS=

# ---- Resend (transactional emails) ----
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=
# Sender address - domain must be verified in Resend dashboard.
# For testing you can use: Taz Trends <onboarding@resend.dev>
RESEND_FROM_EMAIL=Taz Trends <orders@taztrends.com>

# ---- Razorpay ----
# Public key id is exposed to the browser checkout widget.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
